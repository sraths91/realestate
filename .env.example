# RapidAPI Key — powers both Zillow + Realtor.com APIs
# Sign up free at https://rapidapi.com, then subscribe to:
#   - Zillow.com: https://rapidapi.com/apimaker/api/zillow-com1
#   - Realty in US: https://rapidapi.com/apidojo/api/realty-in-us
# One key works for both APIs (~200 free calls/month combined)
RAPIDAPI_KEY=your_rapidapi_key_here

# RentCast API Key — optional fallback for property data
# Sign up free at https://developers.rentcast.io (50 free calls/month)
RENTCAST_API_KEY=your_rentcast_api_key_here

# Walk Score API Key — optional, for Neighborhood Momentum Score
# Sign up free at https://www.walkscore.com/professional/api.php (5,000 calls/day)
WALKSCORE_API_KEY=your_walkscore_api_key_here

# GreatSchools API Key — optional, for school ratings in Momentum Score
# Apply at https://www.greatschools.org/api/ (free for non-commercial use)
GREATSCHOOLS_API_KEY=your_greatschools_api_key_here

# Data directory — for SQLite database and cached data
# On Railway: set to /data and attach a volume at /data
DATA_DIR=./data

# Server port
PORT=4000
