# RapidAPI Key — powers both Zillow + Realtor.com APIs
# Sign up free at https://rapidapi.com, then subscribe to:
#   - Zillow.com: https://rapidapi.com/apimaker/api/zillow-com1
#   - Realty in US: https://rapidapi.com/apidojo/api/realty-in-us
# One key works for both APIs (~200 free calls/month combined)
RAPIDAPI_KEY=your_rapidapi_key_here

# RentCast API Key — optional fallback for property data
# Sign up free at https://developers.rentcast.io (50 free calls/month)
RENTCAST_API_KEY=your_rentcast_api_key_here

# Server port
PORT=4000
